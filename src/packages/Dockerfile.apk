ARG NGINX_VERSION
ARG DISTRO=alpine
ARG OS_VERSION
ARG ARCH

# Stage 0: Base image with prebuilt binaries
FROM fabiocicerchia/nginx-lua:$NGINX_VERSION-$DISTRO$OS_VERSION-$ARCH AS base

# Stage 1: Builder
FROM alpine:3.18 AS build

ARG NGINX_VERSION
ARG ARCH
ENV NGINX_VERSION=$NGINX_VERSION
ENV ARCH=$ARCH

RUN echo "https://dl-cdn.alpinelinux.org/alpine/v3.18/main" > /etc/apk/repositories \
    && echo "https://dl-cdn.alpinelinux.org/alpine/v3.18/community" >> /etc/apk/repositories \
    && apk update \
    && apk add --no-cache alpine-sdk abuild sudo bash gettext-dev libgcc libmaxminddb-dev libxml2-dev pcre-dev

# Add non-root builder
RUN adduser -D builder \
    && addgroup builder abuild \
    && echo "builder ALL=(ALL) NOPASSWD: ALL" >> /etc/sudoers

USER builder
WORKDIR /home/builder/packages/nginx-lua

# Copy APKBUILD and scripts
COPY --chown=builder:builder APKBUILD after-install.sh nginx-lua.post-install /home/builder/packages/nginx-lua/

# Copy files from the base image
COPY --from=base /etc/nginx /etc/nginx
COPY --from=base /usr/sbin/nginx /usr/sbin/nginx
COPY --from=base /usr/sbin/nginx-debug /usr/sbin/nginx-debug
COPY --from=base /usr/local/bin /usr/local/bin
COPY --from=base /usr/local/lib /usr/local/lib
COPY --from=base /usr/local/include /usr/local/include
COPY --from=base /usr/local/etc /usr/local/etc
COPY --from=base /usr/local/share /usr/local/share

# Generate signing key and build
RUN export NGINX_VERSION=$NGINX_VERSION \
    && export ARCH=$(apk --print-arch) \
    && export DISTRO=$DISTRO \
    && export OS_VERSION=$OS_VERSION \
    && abuild-keygen -ain \
    && abuild -r \
    && sudo mv /home/builder/packages/packages/x86_64/nginx-lua-*.apk /
